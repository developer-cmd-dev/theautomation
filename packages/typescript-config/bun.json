{
    "compilerOptions": {
      "lib": ["ESNext","DOM"],
      "module": "ESNext",
      "target": "ESNext",
      "moduleResolution": "bundler",
      "types": ["bun"],
      "strict": true,
      "skipLibCheck": true,
      "allowJs": true,
      "noEmit": true,
      "allowImportingTsExtensions": true,
      "moduleDetection": "force"
    }
  }
  